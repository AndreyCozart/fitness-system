@model IEnumerable<FitnessSystem.Models.GroupClassBooking>
@{
    ViewData["Title"] = "Управление записями";
    var groupClass = ViewBag.GroupClass as FitnessSystem.Models.GroupClass;
}

<h1>Управление записями на занятие</h1>

<div class="alert alert-info">
    <i class="bi bi-info-circle"></i>
    <strong>@groupClass?.Name</strong> - @groupClass?.DayOfWeek,
    @groupClass?.StartTime.ToString(@"hh\:mm") - @groupClass?.EndTime.ToString(@"hh\:mm")
    (Максимум: @groupClass?.MaxParticipants человек)
</div>

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>Клиент</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th>Дата занятия</th>
                    <th>Дата записи</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@(item.Client?.LastName ?? "") @(item.Client?.FirstName ?? "")</td>
                        <td>@(item.Client?.Phone ?? "")</td>
                        <td>@(item.Client?.Email ?? "")</td>
                        <td>@item.ClassDate.ToShortDateString()</td>
                        <td>@item.BookingDate.ToShortDateString()</td>
                        <td>
                            @if (item.IsAttended)
                            {
                                <span class="badge bg-success">Посетил</span>
                            }
                            else if (item.ClassDate < DateTime.Today)
                            {
                                <span class="badge bg-secondary">Не посетил</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Ожидается</span>
                            }
                        </td>
                        <td>
                            <form asp-action="RemoveBooking" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('Вы уверены, что хотите исключить этого клиента из занятия?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" title="Исключить">
                                    <i class="bi bi-person-x"></i> Исключить
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <p class="text-muted">
            <i class="bi bi-people"></i> Всего записей: @Model.Count() / @groupClass?.MaxParticipants
        </p>
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        На это занятие пока никто не записан.
    </div>
}

<div class="mt-3">
    <a asp-action="Details" asp-route-id="@groupClass?.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад к деталям
    </a>
    <a asp-action="Book" asp-route-id="@groupClass?.Id" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить запись
    </a>
</div>