@model FitnessSystem.Models.GroupClass
@{
    ViewData["Title"] = "Детали занятия";
    var upcomingBookings = ViewBag.UpcomingBookings as List<FitnessSystem.Models.GroupClassBooking>;
    var totalBookings = ViewBag.TotalBookings ?? 0;
}

<h1>Детали группового занятия</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@Model.Name</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Инструктор</dt>
                    <dd class="col-sm-8">@Model.Instructor</dd>

                    <dt class="col-sm-4">День недели</dt>
                    <dd class="col-sm-8">@Model.DayOfWeek</dd>

                    <dt class="col-sm-4">Время</dt>
                    <dd class="col-sm-8">@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</dd>

                    <dt class="col-sm-4">Зал</dt>
                    <dd class="col-sm-8">@Model.Room</dd>

                    <dt class="col-sm-4">Максимум участников</dt>
                    <dd class="col-sm-8">@Model.MaxParticipants</dd>

                    <dt class="col-sm-4">Текущих записей</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(totalBookings >= Model.MaxParticipants ? "bg-danger" : "bg-success") fs-6">
                            @totalBookings / @Model.MaxParticipants
                        </span>
                    </dd>

                    <dt class="col-sm-4">Стоимость</dt>
                    <dd class="col-sm-8">@(Model.Price?.ToString("N0") ?? "0") ₽</dd>

                    <dt class="col-sm-4">Статус</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Активно</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Неактивно</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Описание</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Description) ? "Нет описания" : Model.Description)</dd>
                </dl>
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                <a asp-action="ManageBookings" asp-route-id="@Model.Id" class="btn btn-info">
                    <i class="bi bi-people"></i> Управление записями
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-calendar-check"></i> Быстрая запись</h5>
            </div>
            <div class="card-body text-center">
                <p>Запишите клиента на это занятие</p>
                <a asp-action="Book" asp-route-id="@Model.Id" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Записать клиента
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Список записанных клиентов -->
<div class="card mt-4">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-people-fill"></i> Записанные клиенты (@totalBookings)</h5>
    </div>
    <div class="card-body">
        @if (upcomingBookings != null && upcomingBookings.Any())
        {
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Клиент</th>
                        <th>Телефон</th>
                        <th>Дата занятия</th>
                        <th>Дата записи</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in upcomingBookings)
                    {
                        <tr>
                            <td>@(booking.Client?.LastName ?? "") @(booking.Client?.FirstName ?? "")</td>
                            <td>@(booking.Client?.Phone ?? "")</td>
                            <td>@booking.ClassDate.ToShortDateString()</td>
                            <td>@booking.BookingDate.ToShortDateString()</td>
                            <td>
                                @if (booking.IsAttended)
                                {
                                    <span class="badge bg-success">Посетил</span>
                                }
                                else if (booking.ClassDate < DateTime.Today)
                                {
                                    <span class="badge bg-secondary">Не посетил</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Ожидается</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> На это занятие пока никто не записан.
            </div>
        }
    </div>
</div>