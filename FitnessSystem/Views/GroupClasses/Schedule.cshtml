@{
    ViewData["Title"] = "Расписание групповых занятий";

    var weekStart = ViewBag.WeekStart as DateTime?;
    var weekEnd = ViewBag.WeekEnd as DateTime?;
    var prevWeek = ViewBag.PrevWeek as DateTime?;
    var nextWeek = ViewBag.NextWeek as DateTime?;
    var scheduleData = ViewBag.ScheduleData as List<dynamic> ?? new List<dynamic>();
}

<h1 class="mb-4">Расписание групповых занятий</h1>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Schedule" asp-route-weekStart="@prevWeek?.ToString("yyyy-MM-dd")" class="btn btn-outline-primary">
        <i class="bi bi-chevron-left"></i> Предыдущая неделя
    </a>
    <h4 class="bg-primary text-white p-2 rounded">
        <i class="bi bi-calendar-week"></i> @weekStart?.ToShortDateString() - @weekEnd?.ToShortDateString()
    </h4>
    <a asp-action="Schedule" asp-route-weekStart="@nextWeek?.ToString("yyyy-MM-dd")" class="btn btn-outline-primary">
        Следующая неделя <i class="bi bi-chevron-right"></i>
    </a>
</div>

@if (scheduleData != null && scheduleData.Any())
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-primary text-center">
                <tr>
                    @foreach (var day in scheduleData)
                    {
                        <th style="width: 14.28%;">
                            @day.DayName<br />
                            <small class="text-muted">@day.Date.ToShortDateString()</small>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    @foreach (var day in scheduleData)
                    {
                        <td style="vertical-align: top; min-height: 300px; background-color: #f8f9fa;">
                            @if (day.Classes != null && day.Classes.Count > 0)
                            {
                                @foreach (var item in day.Classes)
                                {
                                    <div class="card mb-2 shadow-sm">
                                        <div class="card-body p-2">
                                            <h6 class="card-title mb-1 fw-bold">@item.Class.Name</h6>
                                            <p class="card-text small mb-1">
                                                <i class="bi bi-clock text-primary"></i> @item.Class.StartTime.ToString(@"hh\:mm") - @item.Class.EndTime.ToString(@"hh\:mm")<br />
                                                <i class="bi bi-person text-success"></i> @item.Class.Instructor<br />
                                                <i class="bi bi-door-open text-info"></i> @item.Class.Room
                                            </p>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <span class="badge @(item.BookingsCount >= item.Class.MaxParticipants ? "bg-danger" : "bg-info")">
                                                    <i class="bi bi-people"></i> @item.BookingsCount/@item.Class.MaxParticipants
                                                </span>
                                                @if (item.BookingsCount < item.Class.MaxParticipants)
                                                {
                                                    <a asp-action="Book" asp-route-id="@item.Class.Id" class="btn btn-sm btn-success">
                                                        <i class="bi bi-plus-circle"></i> Записаться
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">
                                                        <i class="bi bi-x-circle"></i> Мест нет
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <i class="bi bi-calendar-x" style="font-size: 2rem;"></i>
                                    <p class="mt-2">Нет занятий</p>
                                </div>
                            }
                        </td>
                    }
                </tr>
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        Нет доступных групповых занятий на эту неделю.
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку занятий
    </a>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Добавить занятие
    </a>
</div>