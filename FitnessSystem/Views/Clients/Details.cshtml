@model FitnessSystem.Models.Client

@{
    ViewData["Title"] = "Детали клиента";
    var visits = ViewBag.ClientVisits as List<FitnessSystem.Models.Visit>;
}

<h1>Детали клиента</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">ФИО</dt>
        <dd class="col-sm-9">@Model.LastName @Model.FirstName @Model.MiddleName</dd>

        <dt class="col-sm-3">Дата рождения</dt>
        <dd class="col-sm-9">@Model.BirthDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Возраст</dt>
        <dd class="col-sm-9">@Model.Age лет</dd>

        <dt class="col-sm-3">Пол</dt>
        <dd class="col-sm-9">@(Model.Gender == "M" ? "Мужской" : "Женский")</dd>

        <dt class="col-sm-3">Телефон</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Дата регистрации</dt>
        <dd class="col-sm-9">@Model.RegistrationDate.ToShortDateString()</dd>

        <dt class="col-sm-3">Примечания</dt>
        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Notes) ? "Нет" : Model.Notes)</dd>
    </dl>
</div>

<h2 class="mt-4">Абонементы клиента</h2>
<p>
    <a asp-controller="MembershipManagement" asp-action="CreateMembership" asp-route-clientId="@Model.Id" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Купить абонемент
    </a>
</p>

@if (Model.Memberships != null && Model.Memberships.Any())
{
    <table class="table table-striped">
        <thead class="table-primary">
            <tr>
                <th>Тип абонемента</th>
                <th>Дата покупки</th>
                <th>Дата начала</th>
                <th>Дата окончания</th>
                <th>Осталось посещений</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var membership in Model.Memberships)
            {
                <tr>
                    <td>@(membership.Type?.TypeName ?? "Н/Д")</td>
                    <td>@membership.PurchaseDate.ToShortDateString()</td>
                    <td>@membership.StartDate.ToShortDateString()</td>
                    <td>@membership.EndDate.ToShortDateString()</td>
                    <td>
                        @if (membership.VisitsRemaining >= 0)
                        {
                            @membership.VisitsRemaining
                        }
                        else
                        {
                            <span class="badge bg-info">Безлимитный</span>
                        }
                    </td>
                    <td>
                        @{
                            var daysLeft = (membership.EndDate - DateTime.Today).Days;
                            var isActive = membership.Status == "active" && membership.EndDate >= DateTime.Today;
                        }
                        @if (isActive)
                        {
                            <span class="badge bg-success">Активный</span>
                            if (daysLeft <= 7)
                            {
                                <br />
                
                                <small class="text-warning">Истекает через @daysLeft дн.</small>
                            }
                        }
                        else if (membership.Status == "frozen")
                        {
                            <span class="badge bg-warning">Заморожен</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Истек</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="MembershipManagement" asp-action="DetailsMembership" asp-route-id="@membership.Id"
                           class="btn btn-sm btn-info" title="Просмотр">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> У клиента нет абонементов
    </div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="bi bi-pencil"></i> Редактировать
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку
    </a>
</div>