@model IEnumerable<FitnessSystem.Models.Client>

@{
    ViewData["Title"] = "Клиенты";
}

<h1>Клиенты</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Добавить клиента
    </a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" class="form-control"
               placeholder="Поиск по фамилии, имени или телефону"
               value="@ViewData["CurrentFilter"]" />
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-search"></i> Поиск
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-counterclockwise"></i> Сброс
        </a>
    </div>
</form>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-primary">
            <tr>
                <th>ФИО</th>
                <th>Дата рождения</th>
                <th>Возраст</th>
                <th>Пол</th>
                <th>Телефон</th>
                <th>Email</th>
                <th>Дата регистрации</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.LastName @item.FirstName @item.MiddleName
                    </td>
                    <td>
                        @item.BirthDate.ToShortDateString()
                    </td>
                    <td>
                        @{
                            var age = DateTime.Today.Year - item.BirthDate.Year;
                            if (item.BirthDate.Date > DateTime.Today.AddYears(-age)) age--;
                        }
                        @age лет
                    </td>
                    <td>
                        @if (item.Gender == "M")
                        {
                            <span>Мужской</span>
                        }
                        else if (item.Gender == "F")
                        {
                            <span>Женский</span>
                        }
                        else
                        {
                            <span>Не указан</span>
                        }
                    </td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.RegistrationDate.ToShortDateString()</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning" title="Редактировать">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-info" title="Просмотр">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger" title="Удалить">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
        {
            <span>По вашему запросу ничего не найдено</span>
        }
        else
        {
            <span>Клиенты не найдены. Добавьте первого клиента!</span>
        }
    </div>
}