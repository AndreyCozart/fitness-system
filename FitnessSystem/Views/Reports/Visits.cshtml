@model FitnessSystem.Models.VisitsReportViewModel

@{
    ViewData["Title"] = "Отчет по посещениям";
}

<h1>Отчет по посещениям</h1>

<div class="card mb-4">
    <div class="card-header card-header-ddh">
        <h5 class="mb-0">Параметры отчета</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row">
            <div class="col-md-4">
                <label class="form-label">Дата начала</label>
                <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Дата окончания</label>
                <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary d-block">Сформировать отчет</button>
            </div>
        </form>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header card-header-ddh">
                <h5 class="mb-0">Общая статистика</h5>
            </div>
            <div class="card-body">
                <p><strong>Период:</strong> @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</p>
                <p><strong>Всего посещений:</strong> @Model.TotalVisits</p>
                <p><strong>Уникальных клиентов:</strong> @Model.UniqueClients</p>
                <p><strong>Среднее посещений в день:</strong> @(Model.TotalVisits > 0 ? (Model.TotalVisits / (Model.EndDate - Model.StartDate).Days).ToString("F1") : "0")</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header card-header-ddh">
                <h5 class="mb-0">Загруженность по часам</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Час</th>
                            <th>Посещений</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.HourlyLoad.OrderBy(h => h.Hour))
                        {
                            <tr>
                                <td>@item.Hour:00 - @(item.Hour + 1):00</td>
                                <td>@item.AverageVisits</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header card-header-ddh">
        <h5 class="mb-0">Ежедневная статистика</h5>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Количество посещений</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DailyVisits)
                {
                    <tr>
                        <td>@item.Date.ToShortDateString()</td>
                        <td>@item.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Назад к отчетам</a>
</div>