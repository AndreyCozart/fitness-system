@{
    ViewData["Title"] = "Отчеты";
}

<h1>Отчеты и аналитика</h1>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Отчет по посещениям</h5>
            </div>
            <div class="card-body">
                <p>Анализ посещаемости за период: общее количество, уникальные клиенты, загруженность по часам.</p>
                <a asp-action="Visits" class="btn btn-primary">Просмотреть отчет</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-cash-stack"></i> Отчет по выручке</h5>
            </div>
            <div class="card-body">
                <p>Анализ продаж абонементов: общая выручка, распределение по типам абонементов.</p>
                <a asp-action="Revenue" class="btn btn-success">Просмотреть отчет</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-people"></i> Групповые занятия</h5>
            </div>
            <div class="card-body">
                <p>Популярность групповых занятий и инструкторов, статистика записей.</p>
                <a asp-action="GroupClasses" class="btn btn-info">Просмотреть отчет</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header bg-warning text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Быстрые отчеты</h5>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Клиенты с истекающими абонементами
                        <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-primary">Перейти</a>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Сегодняшние посещения
                        <a asp-controller="Visits" asp-action="Index" class="btn btn-sm btn-outline-primary">Перейти</a>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Кто сейчас в зале
                        <a asp-controller="Visits" asp-action="Active" class="btn btn-sm btn-outline-primary">Перейти</a>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Расписание групповых занятий
                        <a asp-controller="GroupClasses" asp-action="Schedule" class="btn btn-sm btn-outline-primary">Перейти</a>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Список групповых занятий
                        <a asp-controller="GroupClasses" asp-action="Index" class="btn btn-sm btn-outline-primary">Перейти</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> О системе</h5>
            </div>
            <div class="card-body">
                <p><strong>Информационная система учета занятий</strong></p>
                <p>ООО «ДДХ ФИТНЕС», г. Ставрополь</p>
                <p>Разработано в рамках дипломной работы</p>
                <p><small class="text-muted">Версия 1.0</small></p>
            </div>
        </div>
    </div>
</div>