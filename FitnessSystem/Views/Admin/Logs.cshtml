@model IEnumerable<FitnessSystem.Models.LogEntry>

@{
    ViewData["Title"] = "Журнал действий";
}

<h1>Журнал действий</h1>

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-funnel"></i> Фильтры</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row">
            <div class="col-md-4">
                <label class="form-label">Дата</label>
                <input type="date" name="date" class="form-control" value="@ViewBag.CurrentDate" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Пользователь</label>
                <input type="text" name="username" class="form-control" placeholder="Имя пользователя" value="@ViewBag.CurrentUsername" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-search"></i> Применить
                </button>
                <a asp-action="Logs" class="btn btn-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Сброс
                </a>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-primary">
                <tr>
                    <th>Дата и время</th>
                    <th>Пользователь</th>
                    <th>Действие</th>
                    <th>Контроллер</th>
                    <th>Детали</th>
                    <th>IP адрес</th>
                    <th>Тип</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td class="fw-bold">@item.Username</td>
                        <td>@item.Action</td>
                        <td>@item.Controller</td>
                        <td>@item.Details</td>
                        <td><code>@item.IpAddress</code></td>
                        <td>
                            @if (item.LogType == "Info")
                            {
                                <span class="badge bg-info">Info</span>
                            }
                            else if (item.LogType == "Warning")
                            {
                                <span class="badge bg-warning">Warning</span>
                            }
                            else if (item.LogType == "Error")
                            {
                                <span class="badge bg-danger">Error</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <form asp-action="ClearLogs" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить все логи старше 30 дней?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-trash"></i> Очистить логи старше 30 дней
            </button>
        </form>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Логи не найдены
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>