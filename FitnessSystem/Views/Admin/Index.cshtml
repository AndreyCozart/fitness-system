@{
    ViewData["Title"] = "Панель администратора";
    var username = Context.Session.GetString("Username");
}

<h1>Панель администратора</h1>

<div class="alert alert-success">
    <i class="bi bi-person-circle"></i> Добро пожаловать, <strong>@username</strong>!
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-list-check"></i> Журнал действий</h5>
            </div>
            <div class="card-body">
                <p>Просмотр всех действий пользователей в системе.</p>
                <p class="text-muted small">IP адреса, дата и время, совершенные действия.</p>
                <a asp-action="Logs" class="btn btn-primary">
                    <i class="bi bi-eye"></i> Просмотреть логи
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-box-arrow-right"></i> Выход из системы</h5>
            </div>
            <div class="card-body">
                <p>Завершение сеанса работы в системе.</p>
                <p class="text-muted small">После выхода потребуется повторный вход.</p>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-warning">
                    <i class="bi bi-box-arrow-right"></i> Выйти
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Информация о системе</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Версия</dt>
                    <dd class="col-sm-9">1.0.0</dd>

                    <dt class="col-sm-3">Имя пользователя</dt>
                    <dd class="col-sm-9">@username</dd>

                    <dt class="col-sm-3">IP адрес</dt>
                    <dd class="col-sm-9">@Context.Connection.RemoteIpAddress</dd>

                    <dt class="col-sm-3">Время сервера</dt>
                    <dd class="col-sm-9">@DateTime.Now.ToString("dd.MM.yyyy HH:mm:ss")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>