@{
    ViewData["Title"] = "Доступ запрещен";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white text-center">
                <h4 class="mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Доступ запрещен
                </h4>
            </div>
            <div class="card-body text-center p-4">
                <i class="bi bi-shield-lock text-danger" style="font-size: 4rem;"></i>
                <h5 class="mt-3">У вас нет прав для доступа к этой странице</h5>
                <p class="text-muted">Пожалуйста, войдите в систему с правами администратора</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Войти
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-house"></i> На главную
                </a>
            </div>
        </div>
    </div>
</div>