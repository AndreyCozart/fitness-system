@model IEnumerable<FitnessSystem.Models.Visit>

@{
    ViewData["Title"] = "Клиенты в зале";
}

<h1>Клиенты в зале</h1>

<p>
    <a asp-action="Index" class="btn btn-secondary">Все посещения</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Клиент</th>
            <th>Время входа</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Client?.LastName ?? "Н/Д") @(item.Client?.FirstName ?? "")</td>
                    <td>@item.CheckInTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <form asp-action="CheckOut" asp-route-id="@item.Id" method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-warning">Отметить выход</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">Нет клиентов в зале</td>
            </tr>
        }
    </tbody>
</table>