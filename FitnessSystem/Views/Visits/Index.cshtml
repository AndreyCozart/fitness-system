@model IEnumerable<FitnessSystem.Models.Visit>

@{
    ViewData["Title"] = "Посещения";
}

<h1>Посещения</h1>

<p>
    <a asp-action="CheckIn" class="btn btn-primary">Отметить вход</a>
    <a asp-action="Active" class="btn btn-info">Кто в зале</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Клиент</th>
            <th>Время входа</th>
            <th>Время выхода</th>
            <th>Длительность</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Client?.LastName ?? "Н/Д") @(item.Client?.FirstName ?? "")</td>
                    <td>@item.CheckInTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(item.CheckOutTime?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                    <td>
                        @if (item.CheckOutTime.HasValue)
                        {
                            var duration = item.CheckOutTime.Value - item.CheckInTime;
                            @($"{duration.Hours}ч {duration.Minutes}м")
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td>
                        @if (item.CheckOutTime == null)
                        {
                            <span class="badge bg-success">В зале</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Завершено</span>
                        }
                    </td>
                    <td>
                        @if (item.CheckOutTime == null)
                        {
                            <form asp-action="CheckOut" asp-route-id="@item.Id" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-warning">Отметить выход</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">Нет посещений</td>
            </tr>
        }
    </tbody>
</table>